#include <stdio.h>

void main() {
    int num, i = 0;
    

    int a[20] = {0}; 
    
    printf("Enter number: ");
    scanf("%d", &num);
    
    
    int original_num = num;
    
    
    while (num != 0) {
        a[i] = num % 10;
        num = (num - a[i]) / 10; 
        i++;
    }
    

    int isPalindrome = 1; 
    
    for (int j = 0; j < i / 2; j++) {


        if (a[j] != a[i - 1 - j]) {
            isPalindrome = 0; 
            break;            
        }
    }
    
    if (isPalindrome == 1) {
        printf("It is a palindrome.\n");
    } else {
        printf("Its not a palindrome.\n");
    }

    
}
